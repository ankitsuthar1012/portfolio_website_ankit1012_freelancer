# Server Configuration
PORT=3000

# Allowed Origins (comma-separated for CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Admin Key (for accessing messages endpoint - change this!)
ADMIN_KEY=change-this-to-a-secure-random-string

# Email Notifications (Optional - uncomment and configure to enable)
# NOTIFICATION_EMAIL=your.email@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password

